# Normalize line endings to LF on commit, convert to OS native on checkout
* text=auto eol=lf

# Explicitly binary — never touch line endings
*.docx binary
*.xlsx binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff binary
*.woff2 binary

# Windows scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
